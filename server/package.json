{
  "name": "server",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "migrate:latest": "bun run ./src/db/migrateToLatest.ts",
    "migrate:up": "bun run ./src/db/migrateUp.ts",
    "migrate:down": "bun run ./src/db/migrateDown.ts",
    "db:typegen": "kysely-codegen --out-file ./src/db/schema.ts --singularize",
    "db:seed": "bun run ./src/db/seeders/index.ts"
  },
  "dependencies": {
    "argon2": "^0.44.0",
    "arkenv": "^0.11.0",
    "arktype": "^2.2.0",
    "crypto": "^1.0.1",
    "date-fns": "^4.1.0",
    "hono": "^4.12.14",
    "jose": "^6.2.2",
    "kysely": "^0.28.16",
    "mysql2": "^3.22.2",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.6.0",
    "kysely-codegen": "^0.20.0",
    "typescript": "^6.0.3"
  }
}

# Copy to `.env` next to this compose file (`server/.env`).
# Used by Docker Compose variable substitution — do not commit `.env`.

MYSQL_ROOT_PASSWORD=changeme

# API listen port on the host
# SERVER_PUBLISH_PORT=4000
# MYSQL_PUBLISH_PORT=3306

JWT_SECRET=replace-with-a-long-random-string
ENV=production

# SPA origin exactly as opened in the browser (scheme + host + port).
# When the frontend runs on another host, set this to that public SPA URL so CORS and cookies work.
CORS_ORIGIN=http://localhost:3000

# GIS popup redirect — must match the SPA URL and Google Console Authorized redirect URIs.
GOOGLE_REDIRECT_URI=http://localhost:3000

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

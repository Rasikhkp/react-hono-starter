# Copy to `.env.docker` and use: docker compose --env-file .env.docker up --build
# Or copy/symlink to `.env` for plain `docker compose up --build`.
# Do not commit `.env.docker`.
#
# Public build-time variables only (baked into the SPA bundle).
# Secrets (JWT, GOOGLE_CLIENT_SECRET) belong in server/.env.docker — never use VITE_* for secrets.

# Public URL where the REST API lives (browsers resolve this).
# Example same machine: http://localhost:4000
# Example production: https://api.example.com
VITE_BACKEND_URL=http://localhost:4000

# Optional — enables Google sign-in button (must match server GOOGLE_CLIENT_ID).
# VITE_GOOGLE_CLIENT_ID=

# Host port mapped to container port 80
# WEB_PUBLISH_PORT=3000
